mainmenu "LED Blink Application"

menuconfig LED_SUBSYSTEM
    bool "LED SUBSYSTEM"
    default y
 

if LED_SUBSYSTEM

choice BLINK_SLEEP
    prompt "LED blink speed"
    default BLINK_1000MS

    help
      Select the blink period for the LEDs.

config BLINK_250MS
    bool "250 ms"

config BLINK_500MS
    bool "500 ms"

config BLINK_1000MS
    bool "1000 ms"

config BLINK_2000MS
    bool "2000 ms"

endchoice


# Hidden int — never set by user, derived from choice above
config BLINK_TIME_MS
    int
    default 250  if BLINK_250MS
    default 500  if BLINK_500MS
    default 1000 if BLINK_1000MS
    default 2000 if BLINK_2000MS
    default 0    
    help
      The blink time in milliseconds, derived from the BLINK_SLEEP choice.

# --------------------------------------------------
# Advanced settings
# --------------------------------------------------

menuconfig ADVANCED_LED_SETTINGS
    bool "Advanced LED Settings"
    default n


if ADVANCED_LED_SETTINGS

config LED_BRIGHTNESS
    int "LED brightness level"
    default 100
    range 0 100
    help
      Set the brightness level for the LEDs (0-100%).

config LED_FADE_DURATION
    int "LED fade duration (ms)"
    default 300
    range 0 5000
    help
      Set the duration for LED fade effects in milliseconds.

# --------------------------------------------------
# Expert settings
# --------------------------------------------------

menu "EXPERT SETTINGS"
   visible if ADVANCED_LED_SETTINGS

config Enable_LED_DEBUGGING
    bool "LED diagnostics"

config Enable_Custom_LED_PATTERNS
    bool "Custom LED patterns"


endmenu # EXPERT_SETTINGS

endif # ADVANCED_LED_SETTINGS

endif # LED_SUBSYSTEM



source "Kconfig.zephyr"